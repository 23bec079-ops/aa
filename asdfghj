import pandas as pd
from itertools import product

# Read files
receptors = pd.read_csv("receptors.csv", header=None)
ligands = pd.read_csv("ligands.csv", header=None)

# First column assumed to contain names
receptor_list = receptors.iloc[:, 0].dropna().astype(str).unique()
ligand_list = ligands.iloc[:, 0].dropna().astype(str).unique()

#Drop headers as a pair
receptor_list = [r for r in receptor_list if r != "Receptor"]
ligand_list = [l for l in ligand_list if l != "Ligand"]
receptor_list = [r for r in receptor_list if r != "RECEPTOR"]
ligand_list = [l for l in ligand_list if l != "LIGAND"]

# Generate all combinations
pairs = pd.DataFrame(
    product(receptor_list, ligand_list),
    columns=["Receptor", "Ligand"]
)

#Save
pairs.to_csv('input.csv', index=False)
pd.read_csv('input.csv').to_excel('input.xlsx')

#Display Summary
print(pairs.shape)
print(f"Receptors: {len(receptor_list)}")
print(f"Ligands: {len(ligand_list)}")
print(f"Total pairs: {len(pairs)}")
print("Saved as input.xlsx and input.csv")
