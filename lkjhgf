#!/usr/bin/env python3
"""
split_input.py — split input.xlsx into one chunk per receptor, so each
SLURM array task can dock exactly one receptor against all of its ligands.

Run this ONCE on the login node before submitting the array job (it's
a tiny pandas operation, fine to run interactively):

    python split_input.py

Produces:
    input_chunks/manifest.txt      one absolute path per line, in array
                                    task order (line 0 -> task id 0, etc.)
    input_chunks/000_<Receptor>.xlsx, 001_<Receptor>.xlsx, ...
"""

import os
import pandas as pd

BASE_DIR = os.getcwd()
EXCEL_FILE = os.path.join(BASE_DIR, "input.xlsx")
CHUNK_DIR = os.path.join(BASE_DIR, "input_chunks")
MANIFEST = os.path.join(CHUNK_DIR, "manifest.txt")

os.makedirs(CHUNK_DIR, exist_ok=True)

df = pd.read_excel(EXCEL_FILE)
receptors = df["Receptor"].astype(str).unique()

manifest_lines = []
for i, rec in enumerate(receptors):
    chunk_df = df[df["Receptor"].astype(str) == rec]
    # Safe filename: receptor names here are plain gene symbols (OR10A2 etc.)
    chunk_path = os.path.join(CHUNK_DIR, f"{i:04d}_{rec}.xlsx")
    chunk_df.to_excel(chunk_path, index=False)
    manifest_lines.append(os.path.abspath(chunk_path))

with open(MANIFEST, "w") as f:
    f.write("\n".join(manifest_lines) + "\n")

print(f"Receptors: {len(receptors)}")
print(f"Total pairs: {len(df)}")
print(f"Wrote {len(manifest_lines)} chunk files -> {CHUNK_DIR}/")
print(f"Manifest -> {MANIFEST}")
print(f"\nSet #SBATCH --array=0-{len(manifest_lines)-1} in run_docking.sh")
